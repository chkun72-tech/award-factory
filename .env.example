VITE_APP_TIMEZONE=Australia/Sydney

# Browser-safe public Supabase values. Never put service-role keys in VITE_* values.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only values for migrations, scheduled reminders, and trusted jobs.
DATABASE_URL=postgresql://user:password@localhost:5432/award_factory
SUPABASE_SERVICE_ROLE_KEY=

# Email can stay disabled; app still works.
EMAIL_PROVIDER=disabled
EMAIL_FROM=awards@example.com
AWARD_FACTORY_USER_ID=local-dev-user
